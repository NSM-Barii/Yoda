# Yoda Voice Agent - API Keys Configuration

# ==============================================================================
# OpenAI (LLM + TTS)
# ==============================================================================
# Get key: https://platform.openai.com/api-keys
# Pricing: https://openai.com/api/pricing/
#
# GPT-4o (LLM):
#   - Input:  $2.50 per 1M tokens
#   - Output: $10.00 per 1M tokens
#
# TTS (Text-to-Speech):
#   - $15.00 per 1M characters
#
# Estimated cost: ~$3-8/month for regular testing
OPENAI_API_KEY=sk-...

# ==============================================================================
# Deepgram (Speech-to-Text)
# ==============================================================================
# Get key: https://console.deepgram.com
# Pricing: https://deepgram.com/pricing
#
# Nova-2 STT:
#   - $0.0043 per minute ($0.26/hour)
#   - $200 FREE credits on signup
#
# Estimated cost: FREE for months, then ~$2-5/month
DEEPGRAM_API_KEY=...

# ==============================================================================
# LiveKit - Choose ONE option below
# ==============================================================================

# ---------------------
# OPTION A: Cloud LiveKit (Recommended for Getting Started)
# ---------------------
# Get credentials: https://cloud.livekit.io
# Pricing: https://livekit.io/pricing
#
# Free Tier:
#   - 50 participant hours/month
#   - Good for testing
#
# Paid:
#   - $29/month + usage
#
# Setup: Just paste your cloud credentials below
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxx

# ---------------------
# OPTION B: Self-Hosted LiveKit (Unlimited Free)
# ---------------------
# Requires: Docker on same Linux machine
# Cost: FREE (runs locally)
#
# Start Docker server first:
#   docker run -d --name livekit-server \
#     -p 7880:7880 -p 7881:7881 -p 7882:7882/udp \
#     -e LIVEKIT_KEYS="devkey: devsecret" \
#     livekit/livekit-server --dev
#
# Then use these credentials (DO NOT CHANGE):
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ==============================================================================
# Network Configuration (Optional)
# ==============================================================================
DEFAULT_INTERFACE=wlan0
DEFAULT_SUBNET=192.168.1.0/24

# ==============================================================================
# TOTAL ESTIMATED COSTS
# ==============================================================================
# Cloud LiveKit:   $5-30/month (depends on usage + quota)
# Self-Hosted:     $5-10/month (OpenAI + Deepgram only)
#
# Free credits cover ~2-3 months of testing before any charges
